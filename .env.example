COMPOSE_PROJECT_NAME=lpg-guardian
POSTGRES_DB=lpg_guardian
POSTGRES_USER=lpg_guardian
POSTGRES_PASSWORD=local-development-only
POSTGRES_PORT=5432
REDIS_PORT=6379
CELERY_TASK_ALWAYS_EAGER=false
BACKEND_PORT=8000
FRONTEND_PORT=3000
DJANGO_SECRET_KEY=replace-with-at-least-50-random-characters
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend
CORS_ALLOWED_ORIGINS=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=LPG Guardian <noreply@lpg-guardian.local>
BACKEND_PUBLIC_URL=http://localhost:8000
EMAIL_VERIFICATION_RESEND_COOLDOWN_SECONDS=60
WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
WEB_PUSH_VAPID_SUBJECT=mailto:admin@example.com
