COMPOSE_PROJECT_NAME=lpg-guardian
POSTGRES_DB=lpg_guardian
POSTGRES_USER=lpg_guardian
POSTGRES_PASSWORD=local-development-only
POSTGRES_PORT=5432
REDIS_PORT=6379
BACKEND_PORT=8000
FRONTEND_PORT=3000
